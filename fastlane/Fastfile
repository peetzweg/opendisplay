def asc_api_key
  app_store_connect_api_key(
    key_id:                ENV.fetch("APP_STORE_CONNECT_KEY_ID"),
    issuer_id:             ENV.fetch("APP_STORE_CONNECT_ISSUER_ID"),
    key_content:           ENV.fetch("APP_STORE_CONNECT_KEY_CONTENT"),
    is_key_content_base64: true
  )
end

# CI passes the release version + a monotonic build number through the
# environment; turn them into xcodebuild overrides. Empty when unset, so
# local builds fall back to the defaults in project.yml.
def version_xcargs
  args = []
  version = ENV["APP_MARKETING_VERSION"].to_s
  build   = ENV["APP_BUILD_NUMBER"].to_s
  args << "MARKETING_VERSION=#{version}" unless version.empty?
  args << "CURRENT_PROJECT_VERSION=#{build}" unless build.empty?
  args.join(" ")
end

platform :mac do
  desc "Build Developer ID-signed, notarized macOS app for direct distribution"
  lane :build_release do
    setup_ci if is_ci
    key = asc_api_key
    # Developer ID certs can't be managed via ASC API key — Apple limitation.
    # CI uses readonly: true so it just reads from the git repo, no Apple auth needed.
    match(
      type:           "developer_id",
      app_identifier: "com.peetzweg.opensidecar.mac",
      readonly:       is_ci
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "OpenSidecar.xcodeproj",
      code_sign_identity:    "Developer ID Application",
      profile_name:          "match Direct com.peetzweg.opensidecar.mac macos",
      targets:               ["OpenSidecarMac"]
    )
    build_mac_app(
      project:          "OpenSidecar.xcodeproj",
      scheme:           "OpenSidecarMac",
      configuration:    "Release",
      export_method:    "developer-id",
      output_directory: "build/export",
      output_name:      "OpenSidecar",
      xcargs:           version_xcargs
    )
    # gym/notarize resolve relative paths against the repo root, but during a
    # lane fastlane chdir's the process into fastlane/, so a shell `sh` block
    # (and File.expand_path) would resolve "build/..." under fastlane/ instead.
    # Keep the fastlane actions on repo-root-relative paths, and cd the shell
    # block to the repo root so every path agrees.
    notarize(
      package:   "build/export/OpenSidecar.app",
      bundle_id: "com.peetzweg.opensidecar.mac",
      api_key:   key
    )

    # Wrap the notarized app in a DMG for a friendlier download. Use hdiutil
    # (built-in) rather than create-dmg to avoid the AppleScript window-styling
    # step that is flaky in headless CI. Sign the DMG with the Developer ID
    # identity match installed, then notarize + staple it too — so the
    # downloaded disk image itself passes Gatekeeper without a prompt.
    dmg = "build/export/OpenSidecar.dmg"
    sh(<<~BASH)
      set -euo pipefail
      cd "$(git rev-parse --show-toplevel)"
      rm -rf build/dmg-src
      mkdir -p build/dmg-src
      cp -R build/export/OpenSidecar.app build/dmg-src/
      ln -s /Applications build/dmg-src/Applications
      hdiutil create -volname OpenSidecar -srcfolder build/dmg-src -ov -format UDZO #{dmg}
      codesign --force --sign "Developer ID Application" --timestamp #{dmg}
    BASH
    notarize(
      package:   dmg,
      bundle_id: "com.peetzweg.opensidecar.mac",
      api_key:   key
    )
  end
end

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    setup_ci if is_ci
    key = asc_api_key
    match(
      type:           "appstore",
      app_identifier: "com.peetzweg.opensidecar.ios",
      api_key:        key,
      readonly:       is_ci
    )
    update_code_signing_settings(
      use_automatic_signing: false,
      path:                  "OpenSidecar.xcodeproj",
      code_sign_identity:    "Apple Distribution",
      profile_name:          "match AppStore com.peetzweg.opensidecar.ios",
      targets:               ["OpenSidecariOS"]
    )
    build_app(
      project:          "OpenSidecar.xcodeproj",
      scheme:           "OpenSidecariOS",
      configuration:    "Release",
      export_method:    "app-store",
      output_directory: "build/export",
      output_name:      "OpenSidecariOS",
      xcargs:           version_xcargs
    )
    upload_to_testflight(
      api_key:                           key,
      app_identifier:                    "com.peetzweg.opensidecar.ios",
      skip_waiting_for_build_processing: true
    )
  end
end
