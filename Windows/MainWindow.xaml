<Window x:Class="OpenDisplay.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenDisplay" Icon="Assets/OpenDisplay.ico"
        Width="720" Height="720" MinWidth="620" MinHeight="560"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="OpenDisplay" FontSize="28" FontWeight="SemiBold" />
      <TextBlock Text="Use an iPhone, iPad, or Android tablet as a Windows display."
                 Foreground="Gray" Margin="0,4,0,0" />
    </StackPanel>

    <Border Grid.Row="1" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="Receiver" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid Grid.Row="1">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="Auto" />
          </Grid.ColumnDefinitions>
          <ComboBox Grid.Column="0" ItemsSource="{Binding Devices, Mode=OneWay}"
                    SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
                    DisplayMemberPath="DisplayName" MinWidth="330" />
          <Button Grid.Column="1" Content="Forget" Command="{Binding ForgetManualCommand, Mode=OneWay}"
                  Margin="8,0,0,0" />
          <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand, Mode=OneWay}"
                  Margin="8,0,0,0" />
        </Grid>
        <TextBlock Grid.Row="2" Text="Receivers advertise _opensidecar._tcp on the local network."
                   Foreground="Gray" FontSize="12" Margin="0,6,0,0" />
        <TextBlock Grid.Row="3" Text="Android USB requires Android Platform Tools (adb)."
                   Foreground="Gray" FontSize="12" Margin="0,3,0,0"
                   Visibility="{Binding AdbMissingVisibility, Mode=OneWay}" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="120" />
          <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,14,0">
          <TextBlock Text="Manual address" FontWeight="SemiBold" Margin="0,0,0,6" />
          <DockPanel LastChildFill="True">
            <Button DockPanel.Dock="Right" Content="Connect" Command="{Binding ConnectManualCommand, Mode=OneWay}"
                    Margin="8,0,0,0" />
            <TextBox Text="{Binding ManualHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
              <TextBox.InputBindings>
                <KeyBinding Key="Enter" Command="{Binding ConnectManualCommand, Mode=OneWay}" />
              </TextBox.InputBindings>
            </TextBox>
          </DockPanel>
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,14,0">
          <TextBlock Text="Mode" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Modes, Mode=OneWay}"
                    SelectedItem="{Binding Mode, Mode=TwoWay}" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Quality" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Qualities, Mode=OneWay}"
                    SelectedItem="{Binding Quality, Mode=TwoWay}" />
        </StackPanel>
      </Grid>
    </Border>

    <GroupBox Grid.Row="3" Header="Sessions" Padding="10">
      <Grid>
        <ListView ItemsSource="{Binding Sessions, Mode=OneWay}" BorderThickness="0">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="4,10">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Status, Mode=OneWay}" Foreground="Gray" Margin="0,3,0,0" />
                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,3,0,0">
                      <Run Text="{Binding FramesSent, Mode=OneWay}" /><Run Text=" frames · " />
                      <Run Text="{Binding MegabitsPerSecond, Mode=OneWay, StringFormat={}{0:F1}}" /><Run Text=" Mbps" />
                    </TextBlock>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Disconnect" Command="{Binding DisconnectCommand, Mode=OneWay}"
                          VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <TextBlock Text="No active sessions" Foreground="Gray" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="{Binding EmptySessionsVisibility, Mode=OneWay}" />
      </Grid>
    </GroupBox>

    <Expander Grid.Row="4" Header="Diagnostics" Margin="0,14,0,0">
      <Border BorderBrush="#DDD" BorderThickness="1" CornerRadius="6" Padding="10" Margin="0,6,0,0">
        <StackPanel>
          <TextBox Text="{Binding Diagnostics, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                   AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                   FontFamily="Consolas" FontSize="11" MaxHeight="180" />
          <TextBlock Margin="0,8,0,8" Foreground="Gray" TextWrapping="Wrap">
            <Run Text="Log: " /><Run Text="{Binding LogFilePath, Mode=OneWay}" />
          </TextBlock>
          <StackPanel Orientation="Horizontal">
            <Button Content="Run checks" Command="{Binding RefreshDiagnosticsCommand, Mode=OneWay}" />
            <Button Content="Open log location" Command="{Binding OpenLogCommand, Mode=OneWay}" />
          </StackPanel>
        </StackPanel>
      </Border>
    </Expander>

    <Grid Grid.Row="5" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding SystemStatus, Mode=OneWay}" TextWrapping="Wrap" />
        <TextBlock Text="Extend mode requires VirtualDrivers/Virtual-Display-Driver."
                   Foreground="Gray" FontSize="12" Margin="0,3,0,0" />
      </StackPanel>
      <Button Grid.Column="1" Content="Connect" Command="{Binding ConnectCommand, Mode=OneWay}"
              Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold"
              Margin="16,0,0,0" />
    </Grid>
  </Grid>
</Window>
