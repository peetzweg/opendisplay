<Window x:Class="OpenDisplay.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenDisplay" Icon="Assets/OpenDisplay.ico"
        Width="780" Height="880" MinWidth="680" MinHeight="640"
        Background="{StaticResource WindowBackgroundBrush}"
        WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
      <Grid Margin="24,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Image Width="44" Height="44" Source="Assets/OpenDisplay.ico" />
        <StackPanel Grid.Column="1" Margin="12,1,0,0">
          <TextBlock Text="OpenDisplay" FontSize="20" FontWeight="SemiBold"
                     Foreground="{StaticResource TextPrimaryBrush}" />
          <TextBlock Text="Use your phone or tablet as another Windows display"
                     Foreground="{StaticResource TextSecondaryBrush}" Margin="0,3,0,0" />
        </StackPanel>
      </Grid>
    </Border>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled">
      <StackPanel Margin="24,20,24,24">
        <Border Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Width="30" Height="30" CornerRadius="15"
                      Background="{StaticResource AccentSoftBrush}">
                <TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,12,0">
                <TextBlock Text="Choose a receiver" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="Open OpenDisplay on the device you want to use."
                           Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,0" />
              </StackPanel>
              <Button Grid.Column="2" Content="Refresh devices"
                      Style="{StaticResource SecondaryButtonStyle}"
                      Command="{Binding RefreshCommand, Mode=OneWay}" />
            </Grid>

            <ComboBox Grid.Row="1" Margin="0,16,0,0" Height="50"
                      ItemsSource="{Binding Devices, Mode=OneWay}"
                      SelectedItem="{Binding SelectedDevice, Mode=TwoWay}">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <StackPanel Margin="1,2">
                    <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding TransportLabel, Mode=OneWay}"
                               Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" />
                  </StackPanel>
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Grid.Row="2" Margin="0,8,0,0">
              <TextBlock Text="Devices on USB or this Wi-Fi network appear automatically."
                         Style="{StaticResource SecondaryTextStyle}" />
              <TextBlock Text="Android USB requires Android Platform Tools (adb)."
                         Foreground="{StaticResource WarningBrush}" FontSize="12" Margin="0,4,0,0"
                         Visibility="{Binding AdbMissingVisibility, Mode=OneWay}" />
            </StackPanel>

            <Expander Grid.Row="3" Margin="0,14,0,0"
                      Header="Can't find your device? Connect by IP address">
              <Border Background="{StaticResource SubtleBackgroundBrush}" CornerRadius="6"
                      Padding="12" Margin="0,8,0,0">
                <StackPanel>
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ManualHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="IP address or host:port; port 9000 is used by default">
                      <TextBox.InputBindings>
                        <KeyBinding Key="Enter" Command="{Binding ConnectManualCommand, Mode=OneWay}" />
                      </TextBox.InputBindings>
                    </TextBox>
                    <Button Grid.Column="1" Content="Connect by IP" Margin="8,0,0,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ConnectManualCommand, Mode=OneWay}" />
                  </Grid>
                  <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*" />
                      <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="Enter an address such as 192.168.1.25:9000. It will be remembered."
                               Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" />
                    <Button Grid.Column="1" Content="Remove selected saved address"
                            Style="{StaticResource LinkButtonStyle}"
                            Command="{Binding ForgetManualCommand, Mode=OneWay}" />
                  </Grid>
                </StackPanel>
              </Border>
            </Expander>
          </Grid>
        </Border>

        <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <Border Width="30" Height="30" CornerRadius="15"
                      Background="{StaticResource AccentSoftBrush}">
                <TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center"
                           FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
              </Border>
              <StackPanel Grid.Column="1" Margin="10,0,0,0">
                <TextBlock Text="Choose how to share" Style="{StaticResource SectionTitleStyle}" />
                <TextBlock Text="These settings apply when a new session starts."
                           Style="{StaticResource SecondaryTextStyle}" Margin="0,2,0,0" />
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1" Margin="0,16,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="14" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Border Grid.Column="0" Background="{StaticResource SubtleBackgroundBrush}"
                      CornerRadius="6" Padding="12">
                <StackPanel>
                  <TextBlock Text="Display mode" FontWeight="SemiBold" />
                  <ComboBox ItemsSource="{Binding Modes, Mode=OneWay}"
                            SelectedItem="{Binding Mode, Mode=TwoWay}" Margin="0,8,0,0" />
                  <TextBlock Text="{Binding ModeDescription, Mode=OneWay}"
                             Style="{StaticResource SecondaryTextStyle}"
                             TextWrapping="Wrap" Margin="0,7,0,0" />
                </StackPanel>
              </Border>

              <Border Grid.Column="2" Background="{StaticResource SubtleBackgroundBrush}"
                      CornerRadius="6" Padding="12">
                <StackPanel>
                  <TextBlock Text="Stream quality" FontWeight="SemiBold" />
                  <ComboBox ItemsSource="{Binding Qualities, Mode=OneWay}"
                            SelectedItem="{Binding Quality, Mode=TwoWay}" Margin="0,8,0,0" />
                  <TextBlock Text="{Binding QualityDescription, Mode=OneWay}"
                             Style="{StaticResource SecondaryTextStyle}"
                             TextWrapping="Wrap" Margin="0,7,0,0" />
                </StackPanel>
              </Border>
            </Grid>

            <Grid Grid.Row="2" Margin="0,16,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="Select a receiver above, then start sharing."
                         Style="{StaticResource SecondaryTextStyle}" VerticalAlignment="Center" />
              <Button Grid.Column="1" Content="Start sharing" Width="150" Height="42"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Command="{Binding ConnectCommand, Mode=OneWay}" />
            </Grid>
          </Grid>
        </Border>

        <Border Style="{StaticResource CardStyle}" Margin="0,14,0,0">
          <StackPanel>
            <TextBlock Text="Active sessions" Style="{StaticResource SectionTitleStyle}" />
            <Grid Margin="0,10,0,0" MinHeight="58">
              <ListView ItemsSource="{Binding Sessions, Mode=OneWay}"
                        BorderThickness="0" Background="Transparent">
                <ListView.ItemContainerStyle>
                  <Style TargetType="ListViewItem">
                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                  </Style>
                </ListView.ItemContainerStyle>
                <ListView.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1" Padding="2,10">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Ellipse Width="9" Height="9" Fill="{Binding StatusBrush, Mode=OneWay}"
                                 VerticalAlignment="Top" Margin="0,5,10,0" />
                        <StackPanel Grid.Column="1">
                          <TextBlock Text="{Binding Name, Mode=OneWay}" FontWeight="SemiBold" />
                          <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                     TextWrapping="Wrap" Margin="0,3,0,0">
                            <Run Text="{Binding TransportLabel, Mode=OneWay}" /><Run Text="  ·  " />
                            <Run Text="{Binding Status, Mode=OneWay}" />
                          </TextBlock>
                          <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                     Margin="0,4,0,0">
                            <Run Text="{Binding FramesSent, Mode=OneWay}" /><Run Text=" frames  ·  " />
                            <Run Text="{Binding MegabitsPerSecond, Mode=OneWay, StringFormat={}{0:F1}}" /><Run Text=" Mbps" />
                          </TextBlock>
                        </StackPanel>
                        <Button Grid.Column="2" Content="Disconnect" Margin="12,0,0,0"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding DisconnectCommand, Mode=OneWay}"
                                VerticalAlignment="Center" />
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
              <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                          Visibility="{Binding EmptySessionsVisibility, Mode=OneWay}">
                <TextBlock Text="Nothing is being shared"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Your active devices will appear here."
                           Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                           Margin="0,3,0,0" HorizontalAlignment="Center" />
              </StackPanel>
            </Grid>
          </StackPanel>
        </Border>

        <Expander Header="Troubleshooting and logs" Margin="2,16,2,0">
          <Border Style="{StaticResource CardStyle}" Margin="0,8,0,0">
            <StackPanel>
              <TextBlock Text="Use these details when a device is missing or a session fails."
                         Style="{StaticResource SecondaryTextStyle}" Margin="0,0,0,10" />
              <TextBox Text="{Binding Diagnostics, Mode=OneWay}" IsReadOnly="True"
                       TextWrapping="Wrap" AcceptsReturn="True"
                       VerticalScrollBarVisibility="Auto" FontFamily="Consolas"
                       FontSize="11" MinHeight="90" MaxHeight="190" />
              <TextBlock Margin="0,8" Foreground="{StaticResource TextSecondaryBrush}"
                         TextWrapping="Wrap" FontSize="11">
                <Run Text="Log file: " /><Run Text="{Binding LogFilePath, Mode=OneWay}" />
              </TextBlock>
              <StackPanel Orientation="Horizontal">
                <Button Content="Run checks" Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding RefreshDiagnosticsCommand, Mode=OneWay}" />
                <Button Content="Open log location" Margin="8,0,0,0"
                        Style="{StaticResource SecondaryButtonStyle}"
                        Command="{Binding OpenLogCommand, Mode=OneWay}" />
              </StackPanel>
            </StackPanel>
          </Border>
        </Expander>
      </StackPanel>
    </ScrollViewer>

    <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
            Padding="24,12">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBrush}"
                 VerticalAlignment="Top" Margin="0,5,10,0" />
        <TextBlock Grid.Column="1" Text="{Binding SystemStatus, Mode=OneWay}"
                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
        <TextBlock Grid.Column="2" Text="Runs in the notification area"
                   Foreground="{StaticResource TextMutedBrush}" FontSize="11"
                   Margin="18,1,0,0" VerticalAlignment="Top" />
      </Grid>
    </Border>
  </Grid>
</Window>
