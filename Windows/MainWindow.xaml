<Window x:Class="OpenDisplay.Windows.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OpenDisplay" Width="720" Height="650" MinWidth="620" MinHeight="520"
        WindowStartupLocation="CenterScreen">
  <Grid Margin="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0" Margin="0,0,0,20">
      <TextBlock Text="OpenDisplay" FontSize="28" FontWeight="SemiBold" />
      <TextBlock Text="Use an iPhone, iPad, or Android tablet as a Windows display."
                 Foreground="Gray" Margin="0,4,0,0" />
    </StackPanel>

    <Border Grid.Row="1" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <StackPanel>
          <TextBlock Text="Receiver" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Devices}" SelectedItem="{Binding SelectedDevice}"
                    DisplayMemberPath="DisplayName" MinWidth="330" />
          <TextBlock Text="Receivers advertise _opensidecar._tcp on the local network."
                     Foreground="Gray" FontSize="12" Margin="0,6,0,0" />
        </StackPanel>
        <Button Grid.Column="1" Content="Refresh" Command="{Binding RefreshCommand}"
                VerticalAlignment="Bottom" Margin="14,0,0,0" />
      </Grid>
    </Border>

    <Border Grid.Row="2" Padding="16" BorderBrush="#DDD" BorderThickness="1" CornerRadius="8" Margin="0,0,0,14">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="120" />
          <ColumnDefinition Width="120" />
        </Grid.ColumnDefinitions>
        <StackPanel Grid.Column="0" Margin="0,0,14,0">
          <TextBlock Text="Manual address" FontWeight="SemiBold" Margin="0,0,0,6" />
          <TextBox Text="{Binding ManualHost, UpdateSourceTrigger=PropertyChanged}" />
        </StackPanel>
        <StackPanel Grid.Column="1" Margin="0,0,14,0">
          <TextBlock Text="Mode" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Modes}" SelectedItem="{Binding Mode}" />
        </StackPanel>
        <StackPanel Grid.Column="2">
          <TextBlock Text="Quality" FontWeight="SemiBold" Margin="0,0,0,6" />
          <ComboBox ItemsSource="{Binding Qualities}" SelectedItem="{Binding Quality}" />
        </StackPanel>
      </Grid>
    </Border>

    <GroupBox Grid.Row="3" Header="Sessions" Padding="10">
      <Grid>
        <ListView ItemsSource="{Binding Sessions}" BorderThickness="0">
          <ListView.ItemTemplate>
            <DataTemplate>
              <Border BorderBrush="#E5E5E5" BorderThickness="0,0,0,1" Padding="4,10">
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel>
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Status}" Foreground="Gray" Margin="0,3,0,0" />
                    <TextBlock FontSize="12" Foreground="Gray" Margin="0,3,0,0">
                      <Run Text="{Binding FramesSent}" /><Run Text=" frames · " />
                      <Run Text="{Binding MegabitsPerSecond, StringFormat={}{0:F1}}" /><Run Text=" Mbps" />
                    </TextBlock>
                  </StackPanel>
                  <Button Grid.Column="1" Content="Disconnect" Command="{Binding DisconnectCommand}"
                          VerticalAlignment="Center" Margin="12,0,0,0" />
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
        <TextBlock Text="No active sessions" Foreground="Gray" HorizontalAlignment="Center"
                   VerticalAlignment="Center" Visibility="{Binding EmptySessionsVisibility}" />
      </Grid>
    </GroupBox>

    <Grid Grid.Row="4" Margin="0,16,0,0">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <StackPanel>
        <TextBlock Text="{Binding SystemStatus}" TextWrapping="Wrap" />
        <TextBlock Text="Extend mode requires the OpenDisplay Indirect Display Driver."
                   Foreground="Gray" FontSize="12" Margin="0,3,0,0" />
      </StackPanel>
      <Button Grid.Column="1" Content="Connect" Command="{Binding ConnectCommand}"
              Background="{StaticResource AccentBrush}" Foreground="White" FontWeight="SemiBold"
              Margin="16,0,0,0" />
    </Grid>
  </Grid>
</Window>
